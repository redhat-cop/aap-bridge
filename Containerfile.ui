FROM registry.redhat.io/ubi9/nodejs-20-minimal:latest AS builder

USER 0
WORKDIR /build
COPY web/package.json web/package-lock.json* ./
RUN [ -f package-lock.json ] && npm ci || npm install
COPY web/ ./
RUN npm run build


FROM registry.redhat.io/ubi9/ubi-minimal:latest

RUN microdnf install -y nginx && microdnf clean all

RUN rm -rf /etc/nginx/conf.d/* /usr/share/nginx/html/* && \
    mkdir -p /var/log/nginx /var/cache/nginx /tmp && \
    chown -R 1001:0 /var/log/nginx /var/cache/nginx /tmp /usr/share/nginx/html /etc/nginx

COPY --from=builder /build/dist /usr/share/nginx/html
COPY deploy/nginx.conf /etc/nginx/nginx.conf

EXPOSE 8080

USER 1001

CMD ["nginx", "-g", "daemon off;"]
