# Auto-generated by aap-bridge testing infrastructure
# Pair: AAP {{ source_version }} -> AAP {{ target_version }}
# Generated: {{ ansible_date_time.iso8601 }}
#
# Instance connection settings for this pair. Tuning, phases, export filters, and
# performance defaults come from the shared /app/config/config.yaml (same as laptop).

AAP_BRIDGE_CONFIG=/app/config/config.yaml
AAP_BRIDGE_LOG_LEVEL=INFO

SOURCE__VERSION="{{ source_version }}"
TARGET__VERSION="{{ target_version }}"

# Host URL only; API paths are derived from SOURCE__VERSION / TARGET__VERSION
{% if src_config.components.gateway.enabled | default(false) %}
SOURCE__URL=https://host.containers.internal:{{ src_envoy_port }}
{% else %}
SOURCE__URL=https://host.containers.internal:{{ src_controller_port }}
{% endif %}
SOURCE__TOKEN="{{ source_token }}"  # RO
SOURCE__VERIFY_SSL=false
SOURCE__TIMEOUT=30

{% if tgt_config.components.gateway.enabled | default(false) %}
TARGET__URL=https://host.containers.internal:{{ tgt_envoy_port }}
{% else %}
TARGET__URL=https://host.containers.internal:{{ tgt_controller_port }}
{% endif %}
TARGET__TOKEN="{{ target_token }}"  # RW
TARGET__VERIFY_SSL=false
TARGET__TIMEOUT=30

{% set pg_user = lookup('env', 'POSTGRESQL_USER') | default('aap_migration_user', true) %}
{% set pg_pass = lookup('env', 'POSTGRESQL_PASSWORD') | default(aap_pg_password, true) %}
{% set pg_db = lookup('env', 'POSTGRESQL_DATABASE') | default('aap_migration', true) %}
MIGRATION_STATE_DB_PATH=postgresql://{{ pg_user }}:{{ pg_pass | urlencode }}@db:5432/{{ pg_db }}

PATHS__BASE_DIR=.
PATHS__EXPORT_DIR=exports
PATHS__TRANSFORM_DIR=xformed
PATHS__SCHEMA_DIR=schemas
PATHS__REPORT_DIR=reports
PATHS__BACKUP_DIR=backups
PATHS__MAPPINGS_FILE=config/mappings.yaml

DRY_RUN=false
